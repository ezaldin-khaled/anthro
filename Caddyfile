# When behind a main proxy (shared droplet): main proxy does SSL; Caddy serves HTTP only.
# http:// prefix = no TLS, so the main proxy can forward http://127.0.0.1:9080.
http://anthrotech.ae, http://www.anthrotech.ae {
  reverse_proxy frontend:80 {
    header_up Host {host}
    header_up X-Forwarded-Proto https
  }
}
